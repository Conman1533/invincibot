# Copy this file to .env and fill in your values
# The bot will NOT start without DISCORD_BOT_TOKEN set

# ── Required ──────────────────────────────────────────────────────────────────

# Your bot token from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_bot_token_here

# Password to access the web dashboard at http://localhost:8080
DASHBOARD_SECRET=changeme

# ── Optional (override config.py defaults) ────────────────────────────────────

# Uncomment to change dashboard bind address / port
# DASHBOARD_HOST=0.0.0.0
# DASHBOARD_PORT=8080
